# --------------------------------------------------------------------------
# Database
# --------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./monitoring.db

# --------------------------------------------------------------------------
# Green API (WhatsApp alert delivery)
# Get these values from your instance in the Green API console.
# GREEN_API_URL must match the exact API host shown for your instance —
# it is not always the same for every account.
# --------------------------------------------------------------------------
GREEN_API_INSTANCE_ID=your_instance_id_here
GREEN_API_TOKEN=your_instance_token_here
GREEN_API_URL=https://api.green-api.com

# --------------------------------------------------------------------------
# Monitoring
# How often, in seconds, every active monitor is checked.
# --------------------------------------------------------------------------
CHECK_INTERVAL_SECONDS=60

# --------------------------------------------------------------------------
# Authentication
# DASHBOARD_PASSWORD: required to sign in to the dashboard. Choose a strong value.
# ACCESS_TOKEN_EXPIRE_MINUTES: how long a session stays signed in before
# re-authentication is required.
# --------------------------------------------------------------------------
DASHBOARD_PASSWORD=change_this_password
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --------------------------------------------------------------------------
# Application
# SECRET_KEY signs session tokens. Use a long, random, unique value —
# generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# --------------------------------------------------------------------------
SECRET_KEY=replace_with_a_long_random_string
DEBUG=False